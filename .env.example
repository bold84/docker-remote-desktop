# Docker Remote Desktop Configuration
# Copy this file to .env and customize the values

# User Configuration
USER_NAME=ubuntu
USER_PASSWORD=change_this_password

# User IDs (optional - change if you need specific UID/GID)
# USER_UID=1020
# USER_GID=1020

# Optional: Custom hostname
# HOSTNAME=my-remote-desktop

# Optional: Port mapping (if you want to use a different host port)
# RDP_PORT=3389
